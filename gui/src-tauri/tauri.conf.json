{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "calc",
  "version": "0.1.0",
  "identifier": "io.github.pacharanero.calc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "calc",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Open clinical calculators",
    "longDescription": "Open, auditable clinical calculators. One Rust scoring engine, identical results across CLI, GUI, and embedded hosts. Designed for soft interoperability - every result is one click to the clipboard.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
